# ===========================================
# AI Logger - Environment Configuration
# ===========================================

# Database (SQLite by default - database agnostic design)
DB_LOCATION=database.sqlite
DB_AUTO_LOAD_ENTITIES=true
DB_SYNCHRONIZE=true

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1d

# Server
PORT=8051

# ===========================================
# AI Provider Configuration
# ===========================================

# Provider selection: 'openai', 'ollama', or 'auto' (tries OpenAI first, then Ollama)
AI_PROVIDER=auto

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.3

# Ollama Configuration (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ===========================================
# Notification Channels
# ===========================================

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-domain.com

# Slack
SLACK_WEBHOOK_URL=

# ===========================================
# Future Database Migration (PostgreSQL)
# ===========================================
# Uncomment and configure when migrating to PostgreSQL:
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_DATABASE=ai_logger
